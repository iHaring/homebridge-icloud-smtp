{
  "pluginAlias": "ICloudSMTP",
  "pluginType": "platform",
  "singular": false,
  "displayName": "iCloud SMTP",
  "headerDisplay": "Send emails via iCloud SMTP when switches are triggered",
  "schema": {
    "type": "object",
    "required": [
      "username",
      "password"
    ],
    "properties": {
      "name": {
        "title": "Name",
        "type": "string",
        "default": "iCloud SMTP",
        "description": "Name of this platform instance in Homebridge.",
		"readonly": true
      },
      "username": {
        "title": "iCloud email address (sender)",
        "type": "string",
        "format": "email",
		"placeholder": "your-email@icloud.com",
        "description": "iCloud email used for SMTP authentication and as default recipient if 'to' is not assigned on a switch."
      },
      "password": {
        "title": "App-specific password",
        "type": "string",
        "description": "Generate an app-specific password at https://account.apple.com.",
		"x-schema-form": {
			"type": "password"
		}		
      },
      "switches": {
        "type": "array",
        "minItems": 1,
        "items": {
          "type": "object",
          "required": [
            "name",
            "subject"
          ],
          "properties": {
            "name": {
              "title": "Switch name",
              "type": "string"
            },
            "to": {
              "title": "Recipient email(s)",
              "type": "string",
              "description": "Optional. If empty, uses sender email. Multiple recipients supported (comma-separated).",
              "pattern": "^\\s*[^,\\s@]+@[^,\\s@]+\\.[^,\\s@]+(\\s*,\\s*[^,\\s@]+@[^,\\s@]+\\.[^,\\s@]+)*\\s*$"
            },
            "subject": {
              "title": "Email subject",
              "type": "string"
            },
            "body": {
              "title": "Email body",
              "type": "string"
            },
            "cooldown": {
              "title": "Cooldown (seconds)",
              "type": "number",
              "default": 30,
              "minimum": 0
            }
          }
        }
      }
    }
  }
}
